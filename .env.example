# =============================================================================
# Omni Solutions Global® Co. Ltd. — production template
# Main site: https://omnisolutionsglobal.com
# API host:  https://api.omnisolutionsglobal.com
# Copy to `.env` on the Node server (never commit real secrets).
# =============================================================================

NODE_ENV=production
PORT=3000
# If TLS terminates on Node (unusual behind cPanel): HTTPS_PORT / certs
# HTTPS_PORT=3443
# DISABLE_HTTPS=1

# Public URLs (for ops/docs; optional if your process injects them elsewhere)
OSG_PUBLIC_ORIGIN=https://omnisolutionsglobal.com
OSG_API_PUBLIC_ORIGIN=https://api.omnisolutionsglobal.com

# Strong random secret — required in production
OSG_INSTALL_FP_SALT=

# Browser auf Hauptdomain ruft API auf api.* — alle produktiven **Origins** eintragen (auch www).
# Zusätzliche Kanäle (Capacitor/Ionic/WebView): nach erstem Build den **echten** Origin aus DevTools
# (oder Doku des Wrappers) messen und hier ergänzen, z. B. capacitor://localhost — niemals „*“ in Produktion.
OSG_CORS_ORIGINS=https://omnisolutionsglobal.com,https://www.omnisolutionsglobal.com
# POST/PUT/PATCH/DELETE: Origin oder Referer muss in dieser Liste stehen (meist identisch mit OSG_CORS_ORIGINS).
OSG_API_ALLOWED_ORIGINS=https://omnisolutionsglobal.com,https://www.omnisolutionsglobal.com

# Optional — gleiche Liste erweitern wenn Wrapper live:
# OSG_CORS_ORIGINS=https://omnisolutionsglobal.com,https://www.omnisolutionsglobal.com,capacitor://localhost
# OSG_API_ALLOWED_ORIGINS=https://omnisolutionsglobal.com,https://www.omnisolutionsglobal.com,capacitor://localhost

# HSTS only if Node terminates HTTPS (often off when the hoster/proxy does TLS)
# OSG_ENABLE_HSTS=1

# --- Go-Live: siehe GO-LIVE-CHECKLIST.md im Projektroot ---

# --- Rate limits (optional; defaults in server.js) ---
# OSG_RL_GLOBAL_MAX=800
# OSG_RL_GLOBAL_WINDOW_MS=900000
# OSG_RL_LEAD_MAX=120
# OSG_RL_REF_REGISTER_MAX=40
# OSG_RL_REF_CLAIM_MAX=80
# OSG_RL_REF_STATUS_MAX=240
# OSG_RL_INSTALL_FP_MAX=90
# OSG_RL_VIP_REDEEM_MAX=24
# OSG_RL_CHAT_MAX=40
# OSG_RL_CHAT_WINDOW_MS=3600000
# OSG_RL_TTS_MAX=50
# OSG_RL_TTS_WINDOW_MS=3600000
# OSG_RL_STT_MAX=60
# OSG_RL_STT_WINDOW_MS=3600000
# OSG_RL_CLIP_MAX=30
# OSG_RL_CLIP_WINDOW_MS=3600000
# OSG_RL_PRICES_MAX=180
# OSG_RL_PRICES_WINDOW_MS=900000
# Tagesbremse fuer kostenpflichtige AI-Routen (STT, Foto, Chat, TTS)
# OSG_AI_DAILY_MAX=220

# --- Optional AI / TTS (not required for core lead/referral/VIP) ---
# OPENAI_API_KEY=
# PAULI_OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# Erforderlich für Safari/Firefox Voice-Wake (Whisper STT): OPENAI_API_KEY oder PAULI_OPENAI_API_KEY

# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# Optional: substring regex to pick a voice when VOICE_ID unset (default: first voice in account)
# ELEVENLABS_VOICE_NAME_HINT=

# --- Involve Asia affiliate deeplinks (Lazada / Shopee / Big C marketplace) ---
# Dashboard: Tools → API (Request API Key — approval ~48h on workdays)
# Offer IDs: open each offer page → Promote or URL shows offer_id=…
# INVOLVE_ASIA_API_KEY=
# INVOLVE_ASIA_API_SECRET=
# INVOLVE_ASIA_AFFILIATE_ID=1085689
# OSG_AFFILIATE_PUBLISHER=Omni Solutions Global
# Scope: ID 1085689 nur Retail/E-Commerce (Lazada, Shopee, Big C, Lotus …) — kein Finanz-Modul
# INVOLVE_ASIA_OFFER_LAZADA_TH=
# INVOLVE_ASIA_OFFER_SHOPEE_TH=
# INVOLVE_ASIA_OFFER_BIGC_TH=
# INVOLVE_ASIA_OFFER_LOTUS_TH=
# Optional override for aff_sub (default: paoli_best_price)
# INVOLVE_ASIA_AFF_SUB1=paoli_best_price
# OSG_RL_AFF_DEEPLINK_MAX=18
# OSG_RL_SUPPORT_TICKET_MAX=24
# OSG_SUPPORT_EMAIL=support@omnisolutionsglobal.com
# OSG_INFO_EMAIL=info@omnisolutionsglobal.com
# OSG_SUPPORT_TICKET_START=10001
# OSG_SMTP_HOST=mail.privateemail.com
# OSG_SMTP_PORT=587
# OSG_SMTP_USER=
# OSG_SMTP_PASS=
# OSG_SMTP_FROM=noreply@omnisolutionsglobal.com
# OSG_IMAP_HOST=mail.privateemail.com
# OSG_IMAP_PORT=993
# OSG_RL_ECHO_PROTOCOL_MAX=120

# --- Optional DB (server does not yet implement purchase verification; for your next step) ---
# If you add MySQL on cPanel, use the DSN your provider gives you:
# OSG_DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/DATABASE
# Or SQLite on VPS:
# OSG_SQLITE_PATH=./data/osg-minimal.sqlite
