# =============================================================================
# Store-Zugangsdaten — NUR lokal, NIEMALS committen (.gitignore!)
# Du legst diese Werte selbst an, wenn du dich in den Stores registrierst.
# Kopie: cp stores/credentials.template.env stores/credentials.env
# =============================================================================

# --- Google Play (Rank 1) — https://play.google.com/console ---
# GOOGLE_PLAY_DEVELOPER_ACCOUNT_EMAIL=
# GOOGLE_PLAY_CONSOLE_URL=https://play.google.com/console
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=./secrets/play-service-account.json

# --- Apple (Rank 2) — https://developer.apple.com ---
# APPLE_ID_EMAIL=
# APPLE_TEAM_ID=
# APPLE_DUNS_NUMBER=          # 9-stellig, für Omni Solutions Global Co., Ltd.
# APP_STORE_CONNECT_APP_ID=
# ASC_API_KEY_ID=
# ASC_API_ISSUER_ID=
# ASC_API_KEY_P8_PATH=./secrets/AuthKey_XXXXX.p8

# --- Samsung Galaxy Store (Rank 3) ---
# SAMSUNG_SELLER_EMAIL=
# SAMSUNG_SELLER_PORTAL=https://seller.samsungapps.com/

# --- Xiaomi GetApps (Rank 4) ---
# XIAOMI_DEVELOPER_EMAIL=
# XIAOMI_DEVELOPER_PORTAL=https://global.developer.mi.com/

# --- Amazon / Huawei / OPPO / vivo / Aptoide (Ranks 5–9) ---
# AMAZON_DEVELOPER_EMAIL=
# HUAWEI_DEVELOPER_ID=
# OPPO_OPEN_PLATFORM_EMAIL=
# VIVO_DEVELOPER_EMAIL=
# APTOIDE_DEVELOPER_EMAIL=

# Android release signing (ein Key für alle Android-Stores)
# ANDROID_KEYSTORE_PATH=./secrets/pauli-release.keystore
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=
