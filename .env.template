# Pflicht (deploy-check.sh + server.js Produktionsstart)
NODE_ENV=production
PORT=3000
OSG_INSTALL_FP_SALT=<long-random-secret-min-32-chars>
OSG_CORS_ORIGINS=https://omnisolutionsglobal.com,https://www.omnisolutionsglobal.com
OSG_API_ALLOWED_ORIGINS=https://omnisolutionsglobal.com,https://www.omnisolutionsglobal.com

# =============================================================================
